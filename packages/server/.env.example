# App
PORT=3000
NODE_ENV=development

# JWT (đổi secret trong production)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=8h

# Seed user đầu tiên (chỉ khi bảng users trống)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# MySQL — khớp với docker-compose (hoặc instance của bạn)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=bean
DB_PASSWORD=bean
DB_DATABASE=bean_os

# TypeORM — tắt synchronize trên production, dùng migration
TYPEORM_SYNC=true
DB_LOGGING=false
